# ==============================================================================
# Development Environment Configuration Template
# ==============================================================================
# Copy this file to .env.dev for Docker Compose local development
# Usage: docker-compose --env-file .env.dev up -d

# ==============================================================================
# Database Configuration (PostgreSQL container)
# ==============================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backcast_evs
POSTGRES_PORT=5432

# ==============================================================================
# Backend Configuration
# ==============================================================================

# --- Application Security (LOCAL DEVELOPMENT ONLY!) ---
# WARNING: These values are for local development only.
# Never use these credentials in production.
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Application Settings ---
PROJECT_NAME="Backcast"
API_V1_STR=/api/v1
DEBUG=true
PORT=8020

# --- CORS (Development - allow local dev servers) ---
# Backend accepts requests from these origins
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
BACKEND_CORS_METHODS=["*"]
BACKEND_CORS_HEADERS=["*"]

# --- RBAC Configuration ---
RBAC_POLICY_FILE=config/rbac.json
RBAC_PROVIDER=json
AUTH_PROVIDER=local
USER_PROVIDER=local

# --- OpenTelemetry / Observability ---
# Disabled by default in development
# Enable to trace requests with Arize Phoenix or Jaeger
OTEL_ENABLED=false
OTLP_ENDPOINT=http://localhost:6006/v1/traces

# --- Logging (verbose in development) ---
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
LOG_MAX_BYTES=51200
LOG_BACKUP_COUNT=10

# --- Telegram Admin Notifications (disabled by default) ---
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ==============================================================================
# Frontend Configuration (Vite dev server proxy)
# ==============================================================================

# Backend API URL for frontend proxy
VITE_API_URL=http://localhost:8020

# WebSocket URL for AI chat streaming
VITE_WEBSOCKET_URL=ws://localhost:8020
