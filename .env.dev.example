# === Development Configuration Template ===
# Copy this file to .env.dev for Docker Compose development

# Database Configuration (used by PostgreSQL container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backcast_evs
POSTGRES_PORT=5432

# Application Security (local development only!)
SECRET_KEY=dev-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Application Settings
PROJECT_NAME="Backcast"
API_V1_STR=/api/v1
DEBUG=true
PORT=8020

# CORS (Development - allow local dev servers)
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
BACKEND_CORS_METHODS=["*"]
BACKEND_CORS_HEADERS=["*"]

# Frontend Environment (Vite dev server proxy)
VITE_API_URL=http://localhost:8020
VITE_WEBSOCKET_URL=ws://localhost:8020

# RBAC Policy
RBAC_POLICY_FILE=config/rbac.json

# OpenTelemetry / Arize Phoenix Tracing (disabled by default)
OTEL_ENABLED=false
OTLP_ENDPOINT=http://localhost:6006/v1/traces

# Logging (verbose in development)
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log
LOG_MAX_BYTES=51200
LOG_BACKUP_COUNT=10

# Telegram Admin Notifications (disabled by default)
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
