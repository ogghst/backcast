# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backcast_evs
POSTGRES_SERVER=localhost
# Host Port for local connections
POSTGRES_PORT=5432

# Application Database URL
# Note: Ensure the driver (postgresql+asyncpg) matches your requirements
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# App Security
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# App Settings
PROJECT_NAME="Backcast "
API_V1_STR="/api/v1"
DEBUG=True
PORT=8020

# CORS Configuration
# List of allowed origins. In production, specify exact domains.
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]
BACKEND_CORS_METHODS=["*"]
BACKEND_CORS_HEADERS=["*"]

# Authorization
RBAC_POLICY_FILE=config/rbac.json

# OpenTelemetry / Arize Phoenix Tracing
OTEL_ENABLED=false
OTLP_ENDPOINT=http://localhost:6006/v1/traces

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/app.log
# Maximum size of each log file before rotation (in bytes, default: 51200 = 50 KB)
LOG_MAX_BYTES=51200
# Number of backup log files to keep (default: 10)
LOG_BACKUP_COUNT=10
