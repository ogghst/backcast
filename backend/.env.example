# ==============================================================================
# Backend Environment Configuration Template
# ==============================================================================
# Copy this file to .env and update with your values
#
# Configuration Priority: command line args > .env file > defaults

# ==============================================================================
# Database Configuration
# ==============================================================================

# PostgreSQL connection settings
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=backcast_evs
POSTGRES_SERVER=localhost
POSTGRES_PORT=5432

# SQLAlchemy Database URL
# Format: postgresql+asyncpg://USER:PASSWORD@SERVER:PORT/DATABASE
# Note: Ensure the driver (postgresql+asyncpg) matches your requirements
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_SERVER}:${POSTGRES_PORT}/${POSTGRES_DB}

# ==============================================================================
# Application Security
# ==============================================================================

# Secret key for JWT token signing (REQUIRED - change in production!)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_secure_random_string_in_production

# JWT signing algorithm (default: HS256)
ALGORITHM=HS256

# Access token expiration time in minutes (default: 60)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Refresh token expiration time in days (default: 30)
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==============================================================================
# Application Settings
# ==============================================================================

# Application name (used in API docs and headers)
PROJECT_NAME="Backcast"

# API version prefix
API_V1_STR=/api/v1

# Enable debug mode (development only - disable in production)
DEBUG=true

# Backend server port
PORT=8020

# ==============================================================================
# CORS Configuration
# ==============================================================================

# Allowed CORS origins (JSON array format)
# Development: local dev servers
# Production: exact domains only, e.g., ["https://app.yourdomain.com"]
BACKEND_CORS_ORIGINS=["http://localhost:5173", "http://localhost:3000"]

# Allowed HTTP methods (default: all)
BACKEND_CORS_METHODS=["*"]

# Allowed headers (default: all)
BACKEND_CORS_HEADERS=["*"]

# ==============================================================================
# RBAC (Role-Based Access Control) Configuration
# ==============================================================================

# RBAC Provider: "database" | "entra" (future)
# - database: Loads roles/permissions from database tables
# - entra: Loads from Microsoft Entra ID (future)
RBAC_PROVIDER=database

# Auth Provider: "local" (default) | "oidc" (future)
# - local: JWT-based authentication with local users
# - oidc: OpenID Connect integration (future)
AUTH_PROVIDER=local

# User Provider: "local" (default) | "entra" | "hybrid" (future)
# - local: Users managed in local database
# - entra: Users from Microsoft Entra ID
# - hybrid: Mixed local and Entra users (future)
USER_PROVIDER=local

# ==============================================================================
# OpenTelemetry / Observability
# ==============================================================================

# Enable OpenTelemetry tracing (default: false)
OTEL_ENABLED=false

# OTLP endpoint for trace export (e.g., Arize Phoenix, Jaeger)
OTLP_ENDPOINT=http://localhost:6006/v1/traces

# ==============================================================================
# Logging Configuration
# ==============================================================================

# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
# Development: DEBUG
# Production: INFO or WARNING
LOG_LEVEL=INFO

# Log file path (relative to backend directory or absolute)
LOG_FILE=logs/app.log

# Maximum size of each log file before rotation (in bytes)
# Default: 51200 (50 KB)
# Production recommendation: 10485760 (10 MB)
LOG_MAX_BYTES=51200

# Number of backup log files to keep
# Default: 10
LOG_BACKUP_COUNT=10

# ==============================================================================
# AI Chat Streaming Buffer
# ==============================================================================

# Interval in milliseconds for flushing streaming tokens to the client (default: 2000)
AI_TOKEN_BUFFER_INTERVAL_MS=2000

# AI Agent Orchestrator: "supervisor" (handoff-based, shared state) | "deep" (task-based, isolated)
AI_ORCHESTRATOR=supervisor

# Enable token buffering for streaming (default: true)
AI_TOKEN_BUFFER_ENABLED=true

# Max tokens before forced flush (default: 10000)
AI_TOKEN_BUFFER_MAX_SIZE=10000

# Max retries for transient API errors during specialist execution (default: 3)
AI_SPECIALIST_MAX_RETRIES=3

# Context window limit for the supervisor node (estimated tokens).
# When the message history exceeds the threshold, older messages are
# replaced with the structured briefing document to prevent silent truncation.
# See AI_CONTEXT_TOKEN_LIMIT below for the actual threshold.
# Default: 60000
AI_MODEL_CONTEXT_LIMIT=60000

# ==============================================================================
# AI Specialist Tool Assignments (Optional)
# ==============================================================================
# Override the tool list for each specialist subagent.
# Format: comma-separated tool names. Special values:
#   - "" (empty) = no tools
#   - "*" = all available tools
# If not set, hardcoded defaults from app.ai.subagents are used.

# AI_TOOLS_PROJECT_MANAGER=get_temporal_context,set_temporal_context,global_search,...
# AI_TOOLS_EVM_ANALYST=get_temporal_context,global_search,get_project_analysis,get_project_forecast
# AI_TOOLS_CHANGE_ORDER_MANAGER=get_temporal_context,set_temporal_context,global_search,find_change_orders,...
# AI_TOOLS_USER_ADMIN=get_temporal_context,global_search,find_users,create_user,...
# AI_TOOLS_VISUALIZATION_SPECIALIST=get_temporal_context,global_search
# AI_TOOLS_FORECAST_MANAGER=get_temporal_context,global_search,create_forecast,...
# AI_TOOLS_MCP_SPECIALIST=
# AI_TOOLS_GENERAL_PURPOSE=*

# ==============================================================================
# AI System Runtime Settings
# ==============================================================================
# These control system-level behavior NOT configurable via the UI.
# Agent-level params (model, temperature, max_tokens, etc.) are managed
# through the AI Assistant Config UI and stored in the database.

# Context summarization: max estimated prompt tokens before summarization.
# Older messages are replaced with the structured briefing document.
# Default: 50000
AI_CONTEXT_TOKEN_LIMIT=50000

# Context summarization: percentage of token limit that triggers summarization.
# Default: 80 (i.e., summarize when est. tokens > 80% of AI_CONTEXT_TOKEN_LIMIT)
AI_CONTEXT_SUMMARY_THRESHOLD_PCT=80

# Context summarization: number of recent messages to keep unsummarized.
# Default: 4
AI_CONTEXT_KEEP_RECENT=4

# Delegation enforcement: when a multi-step plan exists, strip ALL domain tools
# from the supervisor, forcing it to delegate via handoff tools only.
# Default: true
AI_DELEGATION_ENFORCED=true

# Sequential tool calls: enforce one tool call at a time to prevent
# DB pool exhaustion and race conditions. Set to false to allow parallel.
# Default: true
AI_SEQUENTIAL_TOOL_CALLS=true

# MCP tool category prefix: used to identify MCP tools for the mcp_specialist.
# Default: "mcp:"
AI_MCP_TOOL_CATEGORY_PREFIX=mcp:

# ==============================================================================
# Telegram Admin Notifications (Optional)
# ==============================================================================

# Enable Telegram notifications for critical errors
TELEGRAM_ENABLED=false

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for notifications (use @userinfobot to get your ID)
TELEGRAM_CHAT_ID=

# ==============================================================================
# RustFS / S3 Storage
# ==============================================================================

# RustFS endpoint URL for S3-compatible storage
RUSTFS_ENDPOINT_URL=http://localhost:9000

# RustFS access key (S3-compatible credentials)
RUSTFS_ACCESS_KEY=rustfsadmin

# RustFS secret key (S3-compatible credentials)
RUSTFS_SECRET_KEY=rustfsadmin

# Default bucket name for document storage
RUSTFS_BUCKET_NAME=backcast-documents
