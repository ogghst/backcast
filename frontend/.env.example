# === Frontend Environment Configuration Template ===
# Copy this file to .env and update with your values
#
# NOTE: All frontend environment variables must be prefixed with VITE_ to be
# accessible in the browser. See: https://vitejs.dev/guide/env-and-mode.html

# ==============================================================================
# API Configuration
# ==============================================================================

# Backend API URL
# The base URL of the backend API server.
# - Development: http://localhost:8020
# - Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:8020

# WebSocket URL (for AI chat streaming)
# The WebSocket endpoint for real-time AI chat streaming.
# - Development: ws://localhost:8020
# - Production: wss://api.yourdomain.com
# If not specified, defaults to VITE_API_URL with ws:// protocol
VITE_WEBSOCKET_URL=ws://localhost:8020

# ==============================================================================
# Build Information (Auto-injected)
# ==============================================================================

# Git commit SHA (auto-injected at build time)
# DO NOT set manually. Injected by the build process for version tracking.
VITE_GIT_SHA=

# Build timestamp (auto-injected at build time)
# DO NOT set manually. Injected by the build process for release identification.
VITE_BUILD_DATE=
