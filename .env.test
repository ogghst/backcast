# Test Environment Configuration
# This file is used for running tests

# Application
ENVIRONMENT=test
DEBUG=true
SECRET_KEY=test-secret-key-for-testing
PORT=8020

# Database - Test (separate from dev and production)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=backcast_test
POSTGRES_PASSWORD=test_password_change_me
POSTGRES_DB=backcast_evs_test

# Database URL for SQLAlchemy (async)
DATABASE_URL=postgresql+asyncpg://backcast_test:test_password_change_me@localhost:5432/backcast_evs_test

# CORS (allow frontend dev server)
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=WARNING

# Test-specific settings
TESTING=true
