# ==============================================================================
# Production Environment Configuration Template
# ==============================================================================
# Copy this file to .env.production and update with your production values
# Usage: docker-compose --env-file .env.production up -d

# ==============================================================================
# Domain & Deployment Configuration
# ==============================================================================

# Primary domain for the application
DOMAIN=yourdomain.com

# Traefik reverse proxy ports
# For Apache/Nginx integration: Use different ports (e.g., 8080/8443)
# and configure Apache/Nginx as reverse proxy to Traefik
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# ==============================================================================
# Database Configuration (PostgreSQL container)
# ==============================================================================
POSTGRES_USER=backcast_prod
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=backcast_evs
POSTGRES_PORT=5432

# ==============================================================================
# Backend Configuration
# ==============================================================================

# --- Application Security (CHANGE THESE IN PRODUCTION!) ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# --- Application Settings ---
PROJECT_NAME=Backcast
API_V1_STR=/api/v1
DEBUG=false
PORT=8080

# --- CORS (Production - explicit domains only) ---
# Specify exact domains; wildcard "*" is not recommended for production
BACKEND_CORS_ORIGINS=["https://app.${DOMAIN}"]
BACKEND_CORS_METHODS=["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
BACKEND_CORS_HEADERS=["*"]

# --- RBAC Configuration ---
# Path to RBAC policy file (only used when RBAC_PROVIDER=json)
RBAC_POLICY_FILE=config/rbac.json

# RBAC Provider: "json" | "database" | "entra"
# - json: Static roles from config file (simple, requires restart to update)
# - database: Dynamic roles from database (admin UI can update, recommended)
RBAC_PROVIDER=database

# Auth Provider: "local" | "oidc"
AUTH_PROVIDER=local

# User Provider: "local" | "entra" | "hybrid"
USER_PROVIDER=local

# --- Traefik / Let's Encrypt SSL ---
TRAEFIK_ACME_EMAIL=admin@yourdomain.com

# --- Logging (Production settings) ---
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# --- Deployment Options ---
# Run database migrations on startup (recommended: true)
RUN_MIGRATIONS=true

# --- OpenTelemetry / Observability ---
# Enable for production monitoring (recommended: true)
OTEL_ENABLED=false
OTLP_ENDPOINT=http://phoenix:6006/v1/traces

# --- Telegram Admin Notifications (Optional) ---
# Configure to receive critical error notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- AI Chat Streaming Buffer ---
# Interval in milliseconds for flushing streaming tokens to the client (default: 2000)
AI_TOKEN_BUFFER_INTERVAL_MS=2000

# --- AI Agent Orchestrator ---
# "supervisor" (handoff-based, shared state) | "deep" (task-based, isolated)
AI_ORCHESTRATOR=supervisor

# ==============================================================================
# Frontend Configuration (Build-time variables)
# ==============================================================================

# These are injected during the Docker build process
# Update docker-compose.yml build args to use these values

# Backend API URL (public-facing)
VITE_API_URL=https://api.${DOMAIN}

# WebSocket URL for AI chat streaming
VITE_WEBSOCKET_URL=wss://api.${DOMAIN}
