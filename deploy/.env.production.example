# === Production Configuration Template ===
# Copy this file to .env.production and update with your values

# Domain Configuration
DOMAIN=yourdomain.com

# Traefik Port Configuration
# Default: Traefik listens on ports 80/443 directly
# For Apache integration: Use different ports (e.g., 8080/8443) and configure Apache as reverse proxy
TRAEFIK_HTTP_PORT=80
TRAEFIK_HTTPS_PORT=443

# Database Configuration
POSTGRES_USER=backcast_prod
POSTGRES_PASSWORD=change_this_secure_password
POSTGRES_DB=backcast_evs
POSTGRES_PORT=5432

# Application Security (CHANGE THESE!)
SECRET_KEY=change_this_to_a_secure_random_string_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Application Settings
PROJECT_NAME=Backcast EVS
API_V1_STR=/api/v1
DEBUG=false
PORT=8080

# CORS (Production - explicit domains only)
BACKEND_CORS_ORIGINS=["https://app.${DOMAIN}"]
BACKEND_CORS_METHODS=["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]
BACKEND_CORS_HEADERS=["*"]

# Traefik / Let's Encrypt
TRAEFIK_ACME_EMAIL=admin@yourdomain.com

# Logging
LOG_LEVEL=INFO
LOG_FILE=/app/logs/app.log

# Deployment
RUN_MIGRATIONS=true
