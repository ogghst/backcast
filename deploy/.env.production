# ==============================================================================
# Production Environment Configuration
# ==============================================================================
# Production Configuration for backcast.duckdns.org
# Apache SSL Termination Setup

# ==============================================================================
# Domain & Deployment Configuration
# ==============================================================================
# Primary domain for the application
DOMAIN=backcast.duckdns.org

# Traefik reverse proxy ports (internal HTTP-only mode)
# For Apache SSL termination: Traefik listens on these ports internally,
# Apache handles external 80/443 and proxies to Traefik
TRAEFIK_HTTP_PORT=8080
TRAEFIK_HTTPS_PORT=8443

# ==============================================================================
# Database Configuration (PostgreSQL container)
# ==============================================================================
POSTGRES_USER=backcast_prod
POSTGRES_PASSWORD=backcast
POSTGRES_DB=backcast_evs
POSTGRES_PORT=5432

# ==============================================================================
# Application Security
# ==============================================================================
# JWT signing secret (production value - keep secure)
SECRET_KEY=LcOCnNRRouE0uIXQDVQeZ8LE6zKxwHyiGa9JXP5fxa1szWoU7Epwt4Lq69m7iMzq++9FqbBA6ZqHr8cJVejKew==

# JWT signing algorithm
ALGORITHM=HS256

# Access token expiration time in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Refresh token expiration time in days
REFRESH_TOKEN_EXPIRE_DAYS=30

# ==============================================================================
# Application Settings
# ==============================================================================
# Application name (used in API docs and headers)
PROJECT_NAME="Backcast"

# API version prefix
API_V1_STR=/api/v1

# Enable debug mode (should be false in production)
DEBUG=false

# Backend server port (internal to Docker network)
PORT=8080

# ==============================================================================
# CORS Configuration
# ==============================================================================
# Allowed CORS origins (explicit domains for production)
# Includes both HTTPS and HTTP (for internal :8080 access)
BACKEND_CORS_ORIGINS=["https://app.backcast.duckdns.org", "https://api.backcast.duckdns.org", "http://api.backcast.duckdns.org:8080", "http://app.backcast.duckdns.org:8080"]

# Allowed HTTP methods (restricted to specific methods)
BACKEND_CORS_METHODS=["GET", "POST", "PUT", "DELETE", "PATCH", "OPTIONS"]

# Allowed headers
BACKEND_CORS_HEADERS=["*"]

# ==============================================================================
# RBAC (Role-Based Access Control) Configuration
# ==============================================================================
# Path to RBAC policy file (used only when RBAC_PROVIDER=json)
RBAC_POLICY_FILE=config/rbac.json

# RBAC Provider: "json" | "database" | "entra"
RBAC_PROVIDER=database

# Auth Provider: "local" | "oidc"
AUTH_PROVIDER=local

# User Provider: "local" | "entra" | "hybrid"
USER_PROVIDER=local

# ==============================================================================
# Traefik / Let's Encrypt (not used with Apache SSL termination)
# ==============================================================================
TRAEFIK_ACME_EMAIL=ogghst@gmail.com

# ==============================================================================
# Logging Configuration
# ==============================================================================
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log file path (inside container)
LOG_FILE=/app/logs/app.log

# Maximum size of each log file before rotation (in bytes)
# Default: 10485760 (10 MB)
LOG_MAX_BYTES=10485760

# Number of backup log files to keep
LOG_BACKUP_COUNT=10

# ==============================================================================
# Deployment Options
# ==============================================================================
# Run database migrations on startup
RUN_MIGRATIONS=false

# ==============================================================================
# OpenTelemetry / Observability
# ==============================================================================
# Enable OpenTelemetry tracing for monitoring
OTEL_ENABLED=false

# OTLP endpoint for trace export (Arize Phoenix)
OTLP_ENDPOINT=http://localhost:6006/v1/traces

# ==============================================================================
# AI Chat Streaming Buffer
# ==============================================================================
# Interval in milliseconds for flushing streaming tokens to the client (default: 2000)
AI_TOKEN_BUFFER_INTERVAL_MS=2000

# AI Agent Orchestrator: "supervisor" (handoff-based, shared state) | "deep" (task-based, isolated)
AI_ORCHESTRATOR=supervisor

# ==============================================================================
# Telegram Admin Notifications
# ==============================================================================
# Enable Telegram notifications for critical errors
TELEGRAM_ENABLED=false

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for notifications (use @userinfobot to get your ID)
TELEGRAM_CHAT_ID=

# ==============================================================================
# Frontend Configuration (Build-time variables)
# ==============================================================================
# These are injected during the Docker build process
# Update docker-compose.yml build args to use these values

# Backend API URL (public-facing)
VITE_API_URL=https://api.backcast.duckdns.org

# WebSocket URL for AI chat streaming
VITE_WEBSOCKET_URL=wss://api.backcast.duckdns.org
